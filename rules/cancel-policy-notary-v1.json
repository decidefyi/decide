{
  "schema_version": "rulebook_v1",
  "rulebook_id": "cancel_policy_notary",
  "version": "2026-07-15",
  "input_schema": {
    "required": [
      "region_supported",
      "plan_supported",
      "vendor_supported",
      "context_complete",
      "missing_context",
      "billing_cadence",
      "policy",
      "notice_days",
      "penalty",
      "vendor",
      "region",
      "plan",
      "policy_rules_version",
      "policy_source_url",
      "policy_source_notes"
    ],
    "properties": {
      "region_supported": { "type": "boolean" },
      "plan_supported": { "type": "boolean" },
      "vendor_supported": { "type": "boolean" },
      "context_complete": { "type": "boolean" },
      "missing_context": { "type": "string" },
      "billing_cadence": { "type": "string" },
      "policy": { "type": "string" },
      "notice_days": { "type": "integer" },
      "penalty": { "type": "string" },
      "vendor": { "type": "string" },
      "region": { "type": "string" },
      "plan": { "type": "string" },
      "policy_rules_version": { "type": "string" },
      "policy_source_url": { "type": "string" },
      "policy_source_notes": { "type": "string" }
    }
  },
  "rules": [
    {
      "rule_id": "review_unsupported_region",
      "priority": 500,
      "condition": { "field": "region_supported", "operator": "eq", "value": false },
      "outcome": {
        "decision": "review",
        "verdict": "UNKNOWN",
        "action": "request_supported_region",
        "reason_code": "NON_US_REGION"
      }
    },
    {
      "rule_id": "review_unsupported_plan",
      "priority": 490,
      "condition": { "field": "plan_supported", "operator": "eq", "value": false },
      "outcome": {
        "decision": "review",
        "verdict": "UNKNOWN",
        "action": "request_supported_plan",
        "reason_code": "NON_INDIVIDUAL_PLAN"
      }
    },
    {
      "rule_id": "review_unsupported_vendor",
      "priority": 480,
      "condition": { "field": "vendor_supported", "operator": "eq", "value": false },
      "outcome": {
        "decision": "review",
        "verdict": "UNKNOWN",
        "action": "request_supported_vendor",
        "reason_code": "UNSUPPORTED_VENDOR"
      }
    },
    {
      "rule_id": "review_missing_context",
      "priority": 470,
      "condition": { "field": "context_complete", "operator": "eq", "value": false },
      "outcome": {
        "decision": "review",
        "verdict": "UNKNOWN",
        "action": "request_required_policy_context",
        "reason_code": "MISSING_REQUIRED_CONTEXT"
      }
    },
    {
      "rule_id": "allow_free_cancel",
      "priority": 300,
      "condition": { "field": "policy", "operator": "eq", "value": "free_cancel" },
      "outcome": {
        "decision": "yes",
        "verdict": "FREE_CANCEL",
        "action": "approve_cancellation_without_penalty",
        "reason_code": "NO_PENALTY"
      }
    },
    {
      "rule_id": "penalty_early_termination_fee",
      "priority": 290,
      "condition": { "field": "policy", "operator": "eq", "value": "etf" },
      "outcome": {
        "decision": "review",
        "verdict": "PENALTY",
        "action": "route_early_termination_fee_review",
        "reason_code": "EARLY_TERMINATION_FEE"
      }
    },
    {
      "rule_id": "deny_locked_contract",
      "priority": 280,
      "condition": { "field": "policy", "operator": "eq", "value": "locked" },
      "outcome": {
        "decision": "no",
        "verdict": "LOCKED",
        "action": "deny_mid_contract_cancellation",
        "reason_code": "CONTRACT_LOCKED"
      }
    }
  ],
  "default_outcome": {
    "decision": "review",
    "verdict": "UNKNOWN",
    "action": "route_cancellation_policy_review",
    "reason_code": "UNKNOWN_POLICY"
  }
}
