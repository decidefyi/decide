# Copy this file to .env.local for local development.
# Do not commit real secret values.

# Required for human yes/no endpoint (server-side)
GEMINI_API_KEY=your_gemini_api_key

# Optional local/preview direct credential. Production /api/decide is protected even when omitted.
# Clients can send either Authorization: Bearer <token> or X-API-Key: <token>
DECIDE_API_KEY=set_a_long_random_decide_api_key
# Set to 1 to enforce the production auth boundary in local or preview environments.
DECIDE_API_AUTH_REQUIRED=0

# Server-to-server Bearer token for the protected Zendesk reference routes.
# Production fails closed if this is absent. Never expose it to browsers or clients.
WORKFLOW_API_TOKEN=set_a_long_random_workflow_token
# Set to 1 to require the workflow token in local or preview environments too.
WORKFLOW_API_AUTH_REQUIRED=0
# CI/local fixture only. Never set this in deployed environments.
WORKFLOW_TEST_MODE=0

# Optional AI-assisted mode deadlines (milliseconds)
DECIDE_GEMINI_TIMEOUT_MS=15000
DECIDE_GEMINI_ATTEMPT_TIMEOUT_MS=5000

# Optional: operator-only smoke for verifying a newly provisioned customer key
DECIDE_SMOKE_API_KEY=set_customer_key_only_when_running_smoke
DECIDE_SMOKE_BASE_URL=https://www.decide.fyi

# Optional: trusted proxy secret for decidesite -> decide internal forwarding
# When set, requests with matching x-decide-proxy-token are treated as trusted proxy calls.
DECIDE_PROXY_SHARED_TOKEN=set_the_same_value_as_decidesite

# Optional: auth token for /api/policy-fetch-hook (recommended for checker browser-hook lane)
POLICY_CHECK_BROWSER_HOOK_TOKEN=set_a_strong_random_token

# Optional: Browserless token used by /api/policy-fetch-hook (first strategy before direct/jina fallback)
POLICY_FETCH_BROWSERLESS_TOKEN=set_if_using_browserless
# Optional Browserless content endpoint override
# POLICY_FETCH_BROWSERLESS_CONTENT_URL=https://chrome.browserless.io/content

# Optional: comma-separated host allowlist for /api/policy-fetch-hook target URLs
# POLICY_FETCH_ALLOWED_HOSTS=en.help.roblox.com,patreon.com,www.patreon.com

# Optional metrics/logging (server-side)
AXIOM_TOKEN=your_axiom_token
AXIOM_DATASET=refund-decide
METRICS_ADMIN_TOKEN=set_a_strong_random_token

# Optional Supabase state store for policy checker (recommended for reducing git artifact churn)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Set to 1 to enable policy event + daily alert sync.
POLICY_SUPABASE_SYNC_ENABLED=0
# Set to 1 to hydrate/save policy checker state files via Supabase.
POLICY_SUPABASE_STATE_SYNC_ENABLED=0
# Set to 1 to suppress committing high-churn persistent state artifacts when Supabase sync is healthy.
POLICY_SUPABASE_SUPPRESS_GIT_STATE=1

# Privacy-minimal MCP adoption telemetry. Use a stable random secret for the
# HMAC caller identifier; raw IP addresses and tool payloads are never stored.
MCP_TELEMETRY_SALT=set_a_strong_random_secret
MCP_TELEMETRY_SUPABASE_ENABLED=0
# Optional secret used only by first-party production checks. A request is
# excluded from adoption totals only when X-Decide-Internal-Probe matches it.
MCP_INTERNAL_PROBE_TOKEN=set_a_different_strong_random_secret

# Optional tracking hardening
# Comma-separated origins for /api/track (example below)
TRACK_ALLOWED_ORIGINS=https://decide.fyi,https://www.decide.fyi
