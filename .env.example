# Copy this file to .env.local for local development.
# Do not commit real secret values.

# Required for human yes/no endpoint (server-side)
GEMINI_API_KEY=your_gemini_api_key

# Optional: require API key auth on /api/decide
# Clients can send either Authorization: Bearer <token> or X-API-Key: <token>
DECIDE_API_KEY=set_a_long_random_decide_api_key

# Optional: trusted proxy secret for decidesite -> decide internal forwarding
# When set, requests with matching x-decide-proxy-token are treated as trusted proxy calls.
DECIDE_PROXY_SHARED_TOKEN=set_the_same_value_as_decidesite

# Optional metrics/logging (server-side)
AXIOM_TOKEN=your_axiom_token
AXIOM_DATASET=refund-decide
METRICS_ADMIN_TOKEN=set_a_strong_random_token

# Optional tracking hardening
# Comma-separated origins for /api/track (example below)
TRACK_ALLOWED_ORIGINS=https://decide.fyi,https://www.decide.fyi
